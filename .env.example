NODE_ENV=development

# Базовый URL Fastify для server-to-server вызовов (ТОЛЬКО сервер).
# Origin без /api/v1 — пути уже включают префикс в сгенерированных типах.
API_INTERNAL_URL=http://localhost:3000

# Публичный адрес самого Next-приложения (доступен и на клиенте).
NEXT_PUBLIC_APP_URL=http://localhost:3001

# WebSocket к Fastify — понадобится на этапе 6.
NEXT_PUBLIC_WS_URL=ws://localhost:3000

# Секрет HMAC-подписи вебхуков (ТОЛЬКО сервер).
WEBHOOK_SECRET=change-me

# Секрет входа в Draft Mode (ТОЛЬКО сервер).
DRAFT_SECRET=change-me

# Общий Redis для кеш-хендлера — только мульти-инстансный self-host (docker).
# Локально не нужен: без него кеш остаётся in-memory.
# REDIS_URL=redis://localhost:6379

# Сквозная трассировка в тот же Jaeger, что у Fastify (OTLP на :4318).
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_SERVICE_NAME=marketplace-web
