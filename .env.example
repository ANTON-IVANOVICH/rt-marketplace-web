NODE_ENV=development

# Базовый URL Fastify для server-to-server вызовов (ТОЛЬКО сервер).
# Origin без /api/v1 — пути уже включают префикс в сгенерированных типах.
API_INTERNAL_URL=http://localhost:3000

# Публичный адрес самого Next-приложения (доступен и на клиенте).
NEXT_PUBLIC_APP_URL=http://localhost:3001

# WebSocket к Fastify — понадобится на этапе 6.
NEXT_PUBLIC_WS_URL=ws://localhost:3000
